<%- include('./includes/head') %>
<%- include('./includes/nav') %>

<div class="container justify-content-center">
  <div class="row py-5"></div>
  <div class="row mt-5 justify-content-center">
    <div class="col-lg-8">

      <h1 class="text-center mb-5">Sign In</h1>

      <form action="/login/login" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group my-4">
          <label for="email">Email address</label>
          <input type="email" class="form-control" id="email" placeholder="name@example.com" name="email">
        </div>

        <div class="form-group my-4">
          <label for="password">Password</label>
          <input type="password" class="form-control" id="password" placeholder="name@example.com" name="password">
        </div>

        <%- include('./includes/messages') %>

        <div class="container text-center">
          <div class="row mt-5 justify-content-center g-0">
            <div class="col-4">
              <button class="btn btn-primary w-100" type="submit">Sign In</button>
            </div>
            <div class="col-2 w-auto mx-5 text-center lh-lg fs-6">or</div>
            <div class="col-4">
              <a href="/createAccount/index">
                <button class="btn btn-secondary w-100" type="button">Create Account</button>
              </a>
            </div>
          </div>
        </div>

      </form>
      <div class="row">
        <div class="col-lg"></div>
        <div class="col-lg"></div>
      </div>
    </div>
  </div>
</div>


<%- include('./includes/footer') %>