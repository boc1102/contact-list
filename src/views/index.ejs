<%- include('./includes/head') %>
<%- include('./includes/nav') %>

<div class="row justify-content-center">
  <div class="col-7 my-4">
    <h1 class="text-center my-5">Contacts</h1>

    <%- include('./includes/messages') %>

    <div class="row justify-content-end my-3">
      <div class="col-2 w-auto">
        <a href="/addContact/index">
          <button class="btn btn-primary">Add Contact</button>
        </a>
      </div>
    </div>

    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Email</th>
          <th>Phone Number</th>
        </tr>
      </thead>

      <tbody class="table-group-divider">
        <% contacts.forEach(contact => { %>
        <tr>
          <td class="overflow-x-auto" style="max-width: 17em;"><%= contact.first_name %></td>
          <td class="overflow-x-auto" style="max-width: 17em;"><%= contact.last_name %></td>
          <td class="overflow-x-auto" style="max-width: 17em;"><%= contact.email %></td>
          <td><%= contact.phone_number %></td>
          <td>
            <a class="me-3" style="text-decoration: none;" href="update/index?<%= new URLSearchParams({ id: contact._id }).toString() %>">
              <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000">
                <path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z" />
              </svg>
            </a>
            <a class="" style="text-decoration: none;" href="delete?<%= new URLSearchParams({ id: contact._id }).toString() %>">
              <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000">
                <path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z" />
              </svg>
            </a>
          </td>
        </tr>

        <% }); %>
      </tbody>
    </table>

  </div>
</div>


<script>
  history.pushState(null, null, location.href);

  window.addEventListener('popstate', () => {
    window.location.replace('/');
  });
</script>

<%- include('./includes/footer') %>